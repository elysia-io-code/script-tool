{
  "scripts": [
    {
      "id": "ssl_pin",
      "name": "获取域名 SSL Pin",
      "description": "输入域名，输出证书公钥的 sha256 pin。依赖系统 openssl 命令。",
      "command": [
        "${python}",
        "${root}/scripts/ssl_pin.py",
        "${domain}",
        "${port}"
      ],
      "inputs": [
        {
          "id": "domain",
          "label": "域名",
          "type": "text",
          "required": true,
          "default": "example.com"
        },
        {
          "id": "port",
          "label": "端口",
          "type": "number",
          "required": true,
          "default": "443"
        }
      ]
    },
    {
      "id": "image_to_ico",
      "name": "1024 图片生成 ICO",
      "description": "选择一张 1024x1024 或其他正方形 PNG/JPG 图片，生成多尺寸 ico 文件。",
      "command": [
        "${python}",
        "${root}/scripts/image_to_ico.py",
        "${image}",
        "${output_dir}/${output_name}",
        "${sizes}"
      ],
      "inputs": [
        {
          "id": "image",
          "label": "图片",
          "type": "image",
          "required": true,
          "filetypes": [
            [
              "图片文件",
              "*.png *.jpg *.jpeg"
            ],
            [
              "所有文件",
              "*.*"
            ]
          ]
        },
        {
          "id": "output_dir",
          "label": "输出目录",
          "type": "folder",
          "required": true,
          "default": "outputs"
        },
        {
          "id": "output_name",
          "label": "文件名",
          "type": "text",
          "required": true,
          "default": "icon.ico"
        },
        {
          "id": "sizes",
          "label": "包含尺寸",
          "type": "multiselect",
          "required": true,
          "options": [
            "16",
            "24",
            "32",
            "48",
            "64",
            "128",
            "256"
          ],
          "default": [
            "16",
            "24",
            "32",
            "48",
            "64",
            "128",
            "256"
          ]
        }
      ]
    },
    {
      "id": "inspect_ico",
      "name": "查看 ICO 图片尺寸",
      "description": "选择一个 ico 文件，查看里面包含的图片数量、尺寸、位深、格式和数据大小。",
      "command": [
        "${python}",
        "${root}/scripts/inspect_ico.py",
        "${ico}"
      ],
      "inputs": [
        {
          "id": "ico",
          "label": "ICO 文件",
          "type": "file",
          "required": true,
          "filetypes": [
            [
              "ICO 文件",
              "*.ico"
            ],
            [
              "所有文件",
              "*.*"
            ]
          ]
        }
      ]
    }
  ]
}
